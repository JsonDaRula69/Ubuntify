# deploy.conf — Template for Ubuntify configuration
# Values marked __REPLACE__ will be prompted on first run.
# This file is created automatically from this template.

USERNAME="__REPLACE__"
REALNAME=""
PASSWORD_HASH="__REPLACE__"
HOSTNAME="__REPLACE__"

# SSH public keys (one per line, or use SSH_KEYS_FILE below)
SSH_KEY=""
SSH_KEYS_FILE=""

# WiFi credentials
WIFI_SSID="__REPLACE__"
WIFI_PASSWORD="__REPLACE__"

# Webhook monitoring (host is auto-detected from this machine's IP on first run)
WEBHOOK_HOST=""
WEBHOOK_PORT="8080"

# Password storage: plaintext, aes256, keychain
ENCRYPTION="plaintext"

# Target Mac Pro SSH hostname/IP (macOS partition)
TARGET_HOST="__REPLACE__"

# Linux host for Manage mode (Ubuntu SSH endpoint, e.g. macpro-linux or 192.168.1.x)
# If not set, defaults to "macpro-linux" (resolved via SSH config)
LINUX_HOST=""

# Remote sudo password (stored encrypted if encryption is enabled)
REMOTE_SUDO_PASSWORD="__REPLACE__"

# Output directory (default: ~/.Ubuntify/)
OUTPUT_DIR=""