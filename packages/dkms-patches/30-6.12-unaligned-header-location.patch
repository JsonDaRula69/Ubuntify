From: Andreas Beckmann <anbe@debian.org>
Date: Thu, 30 Jan 2025 23:59:05 -0500
Subject: Add conditional include for unaligned.h (fix header location in kernel 6.12+)

Bug-Debian: https://bugs.debian.org/1057447

---
 src/wl/sys/wl_linux.c | 8 ++++++++
 1 file changed, 4 insertions(+), 0 deletions(-)
diff --git a/src/wl/sys/wl_linux.c b/src/wl/sys/wl_linux.c
index 46e5ce5..4d618b7 100644
--- a/src/wl/sys/wl_linux.c
+++ b/src/wl/sys/wl_linux.c
@@ -56,7 +56,11 @@
 #include <asm/irq.h>
 #include <asm/pgtable.h>
 #include <asm/uaccess.h>
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 12, 0)
+#include <linux/unaligned.h>
+#else
 #include <asm/unaligned.h>
+#endif
 
 #include <proto/802.1d.h>
 
